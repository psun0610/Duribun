# Supabase project used by the Next.js app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key for admin jobs such as expired disconnect cleanup.
# Never expose this key to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL used for OAuth redirect allow lists and callback construction.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Kakao Local REST API. Use the Kakao Developers REST API key.
KAKAO_REST_API_KEY=
KAKAO_LOCAL_API_BASE_URL=https://dapi.kakao.com

# Supabase Auth provider credentials are configured in the Supabase Dashboard.
# Keep local copies only for operator handoff; app code should not read these.
SUPABASE_AUTH_KAKAO_CLIENT_ID=
SUPABASE_AUTH_KAKAO_CLIENT_SECRET=
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=
SUPABASE_AUTH_NAVER_PROVIDER_ID=custom:naver
SUPABASE_AUTH_NAVER_CLIENT_ID=
SUPABASE_AUTH_NAVER_CLIENT_SECRET=
